{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://e-comeclouz-yd1o.vercel.app/api/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "https://e-comeclouz-yd1o.vercel.app/api"
  }
}
